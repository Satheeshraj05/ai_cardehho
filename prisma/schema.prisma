generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Car {
  id               Int      @id @default(autoincrement())
  make             String
  model            String
  variant          String
  price            Float
  fuelType         String
  transmission     String
  mileage          Float
  safetyRating     Float
  bodyType         String
  seatingCapacity  Int
  engine           String
  imageUrl         String
  pros             String
  cons             String
  createdAt        DateTime @default(now())
}

model SearchHistory {
  id              Int      @id @default(autoincrement())
  query           String
  preferences     String
  recommendations String
  explanation     String
  createdAt       DateTime @default(now())
}
